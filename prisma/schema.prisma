generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  parentSlug     String?
  locationSlug   String   @default("")
  domain         String?  @unique
  logo           String?
  phone          String?
  retellPhoneNumber String?  @unique
  address        String?
  /** Link "Compartir" de la ficha del negocio en Google Maps (opcional; prioridad sobre búsqueda por nombre+dirección) */
  googleMapsPlaceUrl String?
  /** Preset de colores para booking / pantalla pública (ver lib/callendra-themes.ts) */
  themePreset    String   @default("appleDark")
  /** Secreto para URL de pantalla pública /en/display/[slug]?token=… */
  displayToken   String?  @unique
  /** Secreto para iPad / entrada: /[locale]/walk-in/...?token=… (sin límite por IP; reCAPTCHA omitido) */
  walkInToken    String?  @unique
  plan           String   @default("starter")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  ownerId        String

  staff             Staff[]
  services          Service[]
  appointments      Appointment[]
  schedules         Schedule[]
  staffAssignments  StaffAssignment[] @relation("StaffAssignmentLocation")
  serviceLocations  ServiceLocation[] @relation("ServiceLocationLocation")
  owner             Owner             @relation(fields: [ownerId], references: [id])
  staffUsers        StaffUser[]
  staffBreaks       StaffBreak[]
  timeEntries       TimeEntry[]
  clockQrTokens     ClockQrToken[]

  @@index([parentSlug])
}

model Staff {
  id         String  @id @default(cuid())
  businessId String
  name       String
  phone      String?
  email      String?
  photo      String?
  active     Boolean @default(true)
  /** Secret for /[locale]/staff-day?token=… (personal day list, no login). */
  staffDayViewToken String? @unique

  business         Business          @relation(fields: [businessId], references: [id])
  staffAssignments StaffAssignment[]
  appointments     Appointment[]
  schedules        Schedule[]
  staffUsers        StaffUser[]
  staffBreaks       StaffBreak[]
  timeEntries       TimeEntry[]
}

model StaffBreak {
  id         String   @id @default(cuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date       DateTime // calendar day stored as UTC midnight (YYYY-MM-DD)
  startTime  String // "HH:mm"
  duration   Int // minutes
  label      String   @default("Break")
  createdAt  DateTime @default(now())

  @@index([businessId, date])
  @@index([staffId, date])
}

model TimeEntry {
  id         String   @id @default(cuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       String
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())
  /** Cloudinary (or other HTTPS) URL — selfie taken at clock-in/out on staff-day. */
  selfieUrl  String?

  @@index([businessId, timestamp])
  @@index([staffId, timestamp])
}

model ClockQrToken {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  token      String    @unique
  expiresAt  DateTime
  usedBy     String?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([businessId, expiresAt])
}

model Service {
  id         String  @id @default(cuid())
  businessId String
  name       String
  price      Float
  duration   Int
  active     Boolean @default(true)

  business           Business            @relation(fields: [businessId], references: [id])
  serviceLocations   ServiceLocation[]
  appointments       Appointment[]
  appointmentExtras  AppointmentExtra[]
}

model StaffAssignment {
  id         String  @id @default(cuid())
  staffId    String
  businessId String
  active     Boolean @default(true)

  staff    Staff    @relation(fields: [staffId], references: [id])
  location Business @relation("StaffAssignmentLocation", fields: [businessId], references: [id])

  @@unique([staffId, businessId])
  @@index([businessId])
}

model ServiceLocation {
  id         String  @id @default(cuid())
  serviceId  String
  businessId String
  price      Float?
  active     Boolean @default(true)

  service  Service?  @relation(fields: [serviceId], references: [id])
  location Business @relation("ServiceLocationLocation", fields: [businessId], references: [id])

  @@unique([serviceId, businessId])
  @@index([businessId])
}

model Schedule {
  id         String  @id @default(cuid())
  businessId String
  staffId    String
  dayOfWeek  Int
  startTime  String
  endTime    String
  active     Boolean @default(true)

  business Business @relation(fields: [businessId], references: [id])
  staff    Staff    @relation(fields: [staffId], references: [id])
}

model Appointment {
  id          String   @id @default(cuid())
  businessId  String
  staffId     String
  serviceId   String?
  clientName  String
  clientPhone String
  clientEmail String?
  clientIp    String?
  date        DateTime
  status      String   @default("confirmed")
  cancelReason String?
  source      String   @default("web")
  createdAt   DateTime @default(now())

  business Business           @relation(fields: [businessId], references: [id])
  staff    Staff              @relation(fields: [staffId], references: [id])
  service  Service?           @relation(fields: [serviceId], references: [id])
  extras   AppointmentExtra[]
}

/** Add-on service during visit (catalog or custom). Extends block duration from appointment start. */
model AppointmentExtra {
  id               String   @id @default(cuid())
  appointmentId    String
  appointment      Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId        String?
  service          Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  /** When serviceId is null, this is the line label (e.g. "Extra service"). */
  customLabel      String?
  extraDurationMin Int
  linePrice        Float
  createdAt        DateTime @default(now())

  @@index([appointmentId])
}

model Owner {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  createdAt DateTime @default(now())

  businesses Business[]
}

model StaffUser {
  id         String   @id @default(cuid())
  businessId String
  staffId    String?
  name       String
  email      String   @unique
  password   String
  role       String   @default("STAFF")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id])
  staff      Staff?   @relation(fields: [staffId], references: [id])
}

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  email     String?
  usedAt    DateTime?
  usedBy    String?
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  active    Boolean   @default(true)
}

model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
